{
    "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "includes": ["src/**", "*.mjs", "*.ts", "*.mts", "!**/*.css"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 130,
        "lineEnding": "lf"
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "trailingCommas": "all",
            "semicolons": "always"
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "correctness": {
                "useExhaustiveDependencies": "warn"
            },
            "suspicious": {
                "noCommentText": "off",
                "noArrayIndexKey": "off"
            },
            "security": {
                "noDangerouslySetInnerHtml": "off"
            },
            "performance": {
                "noImgElement": "off"
            },
            "nursery": {
                "useSortedClasses": {
                    "level": "warn",
                    "options": {
                        "functions": ["clsx", "cva", "cn", "tw", "twMerge"]
                    }
                }
            }
        }
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on",
                "useSortedKeys": "off"
            }
        }
    }
}
